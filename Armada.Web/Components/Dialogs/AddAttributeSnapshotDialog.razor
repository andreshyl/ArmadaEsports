@inject IAttributeService AttributeService
@inject IDialogService DialogService

<MudDialog>
    <DialogContent>
        <MudStack Spacing="2">
            @for (int i = 0; i < _attrNames.Length; i++)
            {
                var idx = i;
                <MudStack Row="true" AlignItems="AlignItems.Center" Spacing="2">
                    <MudText Typo="Typo.body2" Class="aasd__attr-name">@_attrNames[idx]</MudText>
                    <MudSlider T="int" @bind-Value="_scores[idx]" Min="1" Max="10" Step="1"
                               Color="Color.Warning" Class="aasd__slider" />
                    <MudText Typo="Typo.body2" Class="aasd__attr-score">@_scores[idx]</MudText>
                </MudStack>
            }
            <MudTextField @bind-Value="_notes" Label="Notes (optional)" Variant="Variant.Outlined"
                          FullWidth="true" Lines="2" />
            @if (_error is not null)
            {
                <MudText Typo="Typo.caption" Color="Color.Error">@_error</MudText>
            }

            @if (_snapshots.Any())
            {
                <MudDivider Class="my-1" />
                <MudText Typo="Typo.caption" Class="aasd__history-title">HISTORIAL</MudText>
                <MudStack Spacing="1">
                    @foreach (var snap in _snapshots)
                    {
                        <MudPaper Class="pa-2" Elevation="0" Outlined="true">
                            <MudStack Row="true" AlignItems="AlignItems.Center" Justify="Justify.SpaceBetween">
                                <MudStack Spacing="0">
                                    <MudText Typo="Typo.body2">@snap.SnapshotDate.ToString("yyyy-MM-dd")</MudText>
                                    <MudChip T="string" Size="Size.Small" Class="ttf-chip--gold">@snap.OverallRating.ToString("F1")</MudChip>
                                </MudStack>
                                <MudStack Row="true" Spacing="0">
                                    <MudIconButton Icon="@Icons.Material.Filled.Edit" Size="Size.Small"
                                                   OnClick="@(() => OpenEdit(snap))" />
                                    <MudIconButton Icon="@Icons.Material.Filled.Delete" Size="Size.Small"
                                                   Color="Color.Error" OnClick="@(() => DeleteSnapshot(snap))" />
                                </MudStack>
                            </MudStack>
                            @if (!string.IsNullOrWhiteSpace(snap.Notes))
                            {
                                <MudText Typo="Typo.caption" Color="Color.Secondary">@snap.Notes</MudText>
                            }
                        </MudPaper>
                    }
                </MudStack>
            }
        </MudStack>
    </DialogContent>
    <DialogActions>
        <MudButton OnClick="@(() => MudDialog.Cancel())" Variant="Variant.Text">Cancel</MudButton>
        <MudButton OnClick="Save" Variant="Variant.Filled" Color="Color.Warning" Disabled="_saving">Save</MudButton>
    </DialogActions>
</MudDialog>

@code {
    [CascadingParameter] private IMudDialogInstance MudDialog { get; set; } = null!;
    [Parameter] public Player Player { get; set; } = null!;

    private static readonly string[] _attrNames =
    [
        "Comunicación", "Juego en Equipo", "Posicionamiento", "Decisiones",
        "Reacción",     "Creatividad",     "Consistencia",    "Adaptabilidad",
        "Precisión",    "Compostura"
    ];

    private int[] _scores = Enumerable.Repeat(5, 10).ToArray();
    private string? _notes;
    private string? _error;
    private bool _saving;
    private List<PlayerAttributeSnapshot> _snapshots = [];

    protected override async Task OnInitializedAsync() =>
        _snapshots = await AttributeService.GetSnapshotsByPlayerAsync(Player.Id);

    private async Task Save()
    {
        _saving = true;
        _error = null;
        try
        {
            var byteScores = _scores.Select(s => (byte)s).ToArray();
            await AttributeService.SaveSnapshotAsync(Player.Id, Player.PrimaryPosition?.Code ?? "MCD", byteScores, _notes);
            MudDialog.Close(DialogResult.Ok(true));
        }
        catch (Exception ex)
        {
            _error = $"Error saving: {ex.Message}";
        }
        finally
        {
            _saving = false;
        }
    }

    private async Task OpenEdit(PlayerAttributeSnapshot snap)
    {
        var parameters = new DialogParameters
        {
            { "Player", Player },
            { "Snapshot", snap }
        };
        var dialog = await DialogService.ShowAsync<EditAttributeSnapshotDialog>(
            $"Edit — {snap.SnapshotDate:yyyy-MM-dd}", parameters,
            new DialogOptions { MaxWidth = MaxWidth.Small, FullWidth = true, CloseButton = true });

        if (!(await dialog.Result)!.Canceled)
        {
            _snapshots = await AttributeService.GetSnapshotsByPlayerAsync(Player.Id);
            StateHasChanged();
        }
    }

    private async Task DeleteSnapshot(PlayerAttributeSnapshot snap)
    {
        var result = await DialogService.ShowMessageBox(
            "Delete Snapshot",
            $"Delete snapshot from {snap.SnapshotDate:yyyy-MM-dd}? This cannot be undone.",
            yesText: "Delete", cancelText: "Cancel");

        if (result == true)
        {
            await AttributeService.DeleteSnapshotAsync(snap.Id);
            _snapshots.Remove(snap);
            StateHasChanged();
        }
    }
}
