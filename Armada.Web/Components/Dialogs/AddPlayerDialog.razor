@using ArmadaEsports.Core.Models
@using ModelPosition = ArmadaEsports.Core.Models.Position
@inject IPlayerService PlayerService

<MudDialog>
    <DialogContent>
        <MudStack Spacing="3">
            <MudTextField @bind-Value="_alias" Label="Alias" Variant="Variant.Outlined" FullWidth="true" Required="true" />
            <MudNumericField T="int" @bind-Value="_jerseyNumber" Label="Jersey Number" Variant="Variant.Outlined" FullWidth="true" Min="1" Max="99" />
            <MudSelect T="int" @bind-Value="_primaryPositionId" Label="Primary Position" Variant="Variant.Outlined" FullWidth="true">
                @foreach (var p in _positions)
                {
                    <MudSelectItem T="int" Value="@p.Id">@p.Code — @p.NameEs</MudSelectItem>
                }
            </MudSelect>
            <MudSelect T="int?" @bind-Value="_secondaryPositionId" Label="Secondary Position (optional)" Variant="Variant.Outlined" FullWidth="true" Clearable="true">
                @foreach (var p in _positions)
                {
                    <MudSelectItem T="int?" Value="@((int?)p.Id)">@p.Code — @p.NameEs</MudSelectItem>
                }
            </MudSelect>
            <MudSelect T="int?" @bind-Value="_tertiaryPositionId" Label="Tertiary Position (optional)" Variant="Variant.Outlined" FullWidth="true" Clearable="true">
                @foreach (var p in _positions)
                {
                    <MudSelectItem T="int?" Value="@((int?)p.Id)">@p.Code — @p.NameEs</MudSelectItem>
                }
            </MudSelect>
            <MudDatePicker @bind-Date="_joinedAt" Label="Joined (optional)" Variant="Variant.Outlined" />
            @if (_error is not null)
            {
                <MudText Typo="Typo.caption" Class="apd__error">@_error</MudText>
            }
        </MudStack>
    </DialogContent>
    <DialogActions>
        <MudButton OnClick="@(() => MudDialog.Cancel())" Variant="Variant.Text">Cancel</MudButton>
        <MudButton OnClick="Save" Variant="Variant.Filled" Color="Color.Warning" Disabled="_saving">Save</MudButton>
    </DialogActions>
</MudDialog>

@code {
    [CascadingParameter] private IMudDialogInstance MudDialog { get; set; } = null!;

    private List<ModelPosition> _positions = [];
    private string _alias = string.Empty;
    private int _jerseyNumber;
    private int _primaryPositionId;
    private int? _secondaryPositionId;
    private int? _tertiaryPositionId;
    private DateTime? _joinedAt;
    private string? _error;
    private bool _saving;

    protected override async Task OnInitializedAsync() =>
        _positions = await PlayerService.GetAllPositionsAsync();

    private async Task Save()
    {
        if (string.IsNullOrWhiteSpace(_alias)) { _error = "Alias is required."; return; }
        if (_primaryPositionId == 0) { _error = "Primary position is required."; return; }
        if (await PlayerService.AliasExistsAsync(_alias)) { _error = "Alias already taken."; return; }
        if (await PlayerService.JerseyNumberExistsAsync(_jerseyNumber)) { _error = "Jersey number already taken."; return; }

        _saving = true;
        await PlayerService.CreateAsync(new Player
        {
            Alias = _alias.Trim(),
            JerseyNumber = _jerseyNumber,
            PrimaryPositionId = _primaryPositionId,
            SecondaryPositionId = _secondaryPositionId,
            TertiaryPositionId = _tertiaryPositionId,
            JoinedAt = _joinedAt.HasValue ? DateOnly.FromDateTime(_joinedAt.Value) : null,
        });
        MudDialog.Close(DialogResult.Ok(true));
    }
}
