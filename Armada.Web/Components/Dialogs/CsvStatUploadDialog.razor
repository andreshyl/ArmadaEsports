@using Microsoft.AspNetCore.Components.Forms
@inject IMatchService MatchService
@inject IPlayerService PlayerService

<MudDialog>
    <DialogContent>
        <MudStack Spacing="3">

            <MudSelect T="int" @bind-Value="_matchId" Label="Match" Variant="Variant.Outlined" FullWidth="true">
                @foreach (var m in Matches.Where(m => m.Status == EMatchStatus.Finished))
                {
                    <MudSelectItem T="int" Value="@m.Id">@m.MatchDate.ToString("dd MMM") — vs @m.OpponentName</MudSelectItem>
                }
            </MudSelect>

            <!-- CSV Format Reference -->
            <MudExpansionPanels Elevation="0">
                <MudExpansionPanel Text="CSV Format" Class="mdd__meta">
                    <MudText Typo="Typo.caption" Style="font-family:monospace;white-space:pre-wrap;font-size:0.65rem;">
                        alias,goals,assists,pass_accuracy_pct,shot_accuracy_pct,tackles,tackles_won,interceptions,saves,match_rating

                        mrfijiwiji30,1,0,81,40,6,1,2,0,6.4
                        Dangerhill,0,1,76,0,3,1,1,0,6.8
                    </MudText>
                    <MudButton Size="Size.Small" Variant="Variant.Text" Color="Color.Warning"
                               OnClick="DownloadTemplate">
                        Download Template
                    </MudButton>
                </MudExpansionPanel>
            </MudExpansionPanels>

            <InputFile id="csv-file-input" OnChange="OnFileSelected" accept=".csv" style="display:none;" />
            <label for="csv-file-input" style="width:100%;">
                <MudButton Variant="Variant.Outlined" Color="Color.Default" FullWidth="true"
                           StartIcon="@Icons.Material.Filled.TableChart" Style="pointer-events:none;">
                    @(_fileName ?? "Select CSV file")
                </MudButton>
            </label>

            @if (_rows.Any())
            {
                <MudDivider />
                <MudText Typo="Typo.caption" Class="aud__rows-label">
                    @_rows.Count rows parsed — match players before saving:
                </MudText>

                @foreach (var row in _rows)
                {
                    <div class="aud__row">
                        <MudSelect T="int?" @bind-Value="row.PlayerId" Label="Player"
                                   Variant="Variant.Outlined" Dense="true" Class="aud__row-select">
                            @foreach (var p in _players)
                            {
                                <MudSelectItem T="int?" Value="@((int?)p.Id)">@p.Alias</MudSelectItem>
                            }
                        </MudSelect>
                        <MudText Typo="Typo.caption" Class="aud__row-alias">@row.RawAlias</MudText>
                        <MudChip T="string" Size="Size.Small" Class="@(row.PlayerId.HasValue ? "ttf-chip--win" : "ttf-chip--loss")">
                            @(row.PlayerId.HasValue ? "✓" : "?")
                        </MudChip>
                    </div>
                }

                @if (_parseErrors.Any())
                {
                    @foreach (var err in _parseErrors)
                    {
                        <MudAlert Severity="Severity.Warning" Dense="true">@err</MudAlert>
                    }
                }

                <MudButton Variant="Variant.Filled" Color="Color.Warning" FullWidth="true"
                           Disabled="@(_saving || _matchId == 0)"
                           OnClick="Save">
                    @(_saving ? "Saving..." : $"Import {_rows.Count(r => r.PlayerId.HasValue)} Players")
                </MudButton>
            }

            @if (_error is not null)
            {
                <MudAlert Severity="Severity.Error" Dense="true">@_error</MudAlert>
            }
        </MudStack>
    </DialogContent>
    <DialogActions>
        <MudButton OnClick="@(() => MudDialog.Close(DialogResult.Ok(true)))" Variant="Variant.Text">Close</MudButton>
    </DialogActions>
</MudDialog>

@code {
    [CascadingParameter] private IMudDialogInstance MudDialog { get; set; } = null!;
    [Parameter] public List<Match> Matches { get; set; } = [];

    [Inject] private IJSRuntime JS { get; set; } = null!;

    private List<Player> _players = [];
    private int _matchId;
    private string? _fileName;
    private string? _error;
    private bool _saving;
    private List<CsvRow> _rows = [];
    private List<string> _parseErrors = [];

    private class CsvRow
    {
        public string RawAlias { get; set; } = string.Empty;
        public int? PlayerId { get; set; }
        public byte Goals { get; set; }
        public byte Assists { get; set; }
        public decimal? PassAccuracyPct { get; set; }
        public decimal? ShotAccuracyPct { get; set; }
        public byte Tackles { get; set; }
        public byte TacklesWon { get; set; }
        public byte Interceptions { get; set; }
        public byte Saves { get; set; }
        public decimal? MatchRating { get; set; }
    }

    protected override async Task OnInitializedAsync() =>
        _players = await PlayerService.GetAllAsync();

    private async Task OnFileSelected(InputFileChangeEventArgs e)
    {
        _rows.Clear();
        _parseErrors.Clear();
        _error = null;

        var file = e.File;
        _fileName = file.Name;

        using var reader = new System.IO.StreamReader(file.OpenReadStream(maxAllowedSize: 1 * 1024 * 1024));
        var content = await reader.ReadToEndAsync();
        var lines = content.Split('\n', StringSplitOptions.RemoveEmptyEntries);

        // Skip header
        foreach (var line in lines.Skip(1))
        {
            var parts = line.Trim().Split(',');
            if (parts.Length < 2) continue;

            try
            {
                var alias = parts[0].Trim();
                var row = new CsvRow
                {
                    RawAlias = alias,
                    Goals = parts.Length > 1 ? byte.Parse(parts[1].Trim()) : (byte)0,
                    Assists = parts.Length > 2 ? byte.Parse(parts[2].Trim()) : (byte)0,
                    PassAccuracyPct = parts.Length > 3 && !string.IsNullOrWhiteSpace(parts[3]) ? decimal.Parse(parts[3].Trim()) : null,
                    ShotAccuracyPct = parts.Length > 4 && !string.IsNullOrWhiteSpace(parts[4]) ? decimal.Parse(parts[4].Trim()) : null,
                    Tackles = parts.Length > 5 ? byte.Parse(parts[5].Trim()) : (byte)0,
                    TacklesWon = parts.Length > 6 ? byte.Parse(parts[6].Trim()) : (byte)0,
                    Interceptions = parts.Length > 7 ? byte.Parse(parts[7].Trim()) : (byte)0,
                    Saves = parts.Length > 8 ? byte.Parse(parts[8].Trim()) : (byte)0,
                    MatchRating = parts.Length > 9 && !string.IsNullOrWhiteSpace(parts[9]) ? decimal.Parse(parts[9].Trim()) : null,
                };

                // Auto-match player by alias (case-insensitive)
                row.PlayerId = _players
                    .FirstOrDefault(p => p.Alias.Equals(alias, StringComparison.OrdinalIgnoreCase))?.Id;

                _rows.Add(row);
            }
            catch (Exception ex)
            {
                _parseErrors.Add($"Line error: \"{line.Trim()}\" — {ex.Message}");
            }
        }
    }

    private async Task Save()
    {
        _saving = true;
        _error = null;
        try
        {
            foreach (var row in _rows.Where(r => r.PlayerId.HasValue))
            {
                await MatchService.AddPerformanceStatAsync(new MatchPerformanceStat
                {
                    MatchId = _matchId,
                    PlayerId = row.PlayerId!.Value,
                    Goals = row.Goals,
                    Assists = row.Assists,
                    PassAccuracyPct = row.PassAccuracyPct,
                    ShotAccuracyPct = row.ShotAccuracyPct,
                    Tackles = row.Tackles,
                    TacklesWon = row.TacklesWon,
                    Interceptions = row.Interceptions,
                    Saves = row.Saves,
                    MatchRating = row.MatchRating,
                    IsAiParsed = false,
                    ConfirmedAt = DateTime.UtcNow,
                });
            }
            MudDialog.Close(DialogResult.Ok(true));
        }
        catch (Exception ex)
        {
            _error = ex.Message;
        }
        finally
        {
            _saving = false;
        }
    }

    private async Task DownloadTemplate()
    {
        const string csv = "alias,goals,assists,pass_accuracy_pct,shot_accuracy_pct,tackles,tackles_won,interceptions,saves,match_rating\nmrfijiwiji30,1,0,81,40,6,1,2,0,6.4\nDangerhill,0,1,76,0,3,1,1,0,6.8";
        var bytes = System.Text.Encoding.UTF8.GetBytes(csv);
        var base64 = Convert.ToBase64String(bytes);
        await JS.InvokeVoidAsync("eval",
            $"const a=document.createElement('a');a.href='data:text/csv;base64,{base64}';a.download='match_stats_template.csv';a.click()");
    }
}
