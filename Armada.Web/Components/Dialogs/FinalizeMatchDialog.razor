@inject IMatchService MatchService

<MudDialog>
    <TitleContent>
        <div class="fmd__header">
            <span class="fmd__title">FINALIZAR PARTIDO</span>
            <span class="fmd__subtitle">@Match.OpponentName.ToUpper()</span>
        </div>
    </TitleContent>
    <DialogContent>
        <div class="fmd__scoreboard">
            <div class="fmd__score-col">
                <span class="fmd__team-label">TTF ESPORTS</span>
                <MudNumericField T="int" @bind-Value="_goalsFor" Variant="Variant.Outlined"
                                 Min="0" Class="fmd__score-input fmd__score-input--us" />
            </div>
            <span class="fmd__dash">—</span>
            <div class="fmd__score-col">
                <span class="fmd__team-label fmd__team-label--opp">@Match.OpponentName.ToUpper()</span>
                <MudNumericField T="int" @bind-Value="_goalsAgainst" Variant="Variant.Outlined"
                                 Min="0" Class="fmd__score-input fmd__score-input--opp" />
            </div>
        </div>
        <div class="fmd__result-preview fmd__result-preview--@ResultClass()">
            @ResultPreview()
        </div>
    </DialogContent>
    <DialogActions>
        <MudButton OnClick="@(() => MudDialog.Cancel())" Variant="Variant.Text">Cancel</MudButton>
        <MudButton OnClick="Save" Variant="Variant.Filled" Color="Color.Warning">Confirm Result</MudButton>
    </DialogActions>
</MudDialog>

@code {
    [CascadingParameter] private IMudDialogInstance MudDialog { get; set; } = null!;
    [Parameter] public Match Match { get; set; } = null!;

    private int _goalsFor;
    private int _goalsAgainst;

    private string ResultPreview() => (_goalsFor, _goalsAgainst) switch
    {
        var (f, a) when f > a => $"Victoria  {f} — {a}",
        var (f, a) when f < a => $"Derrota  {f} — {a}",
        var (f, a) => $"Empate  {f} — {a}",
    };

    private string ResultClass() => (_goalsFor, _goalsAgainst) switch
    {
        var (f, a) when f > a => "w",
        var (f, a) when f < a => "l",
        _ => "d",
    };

    private async Task Save()
    {
        await MatchService.FinalizeAsync(Match.Id, (byte)_goalsFor, (byte)_goalsAgainst);
        MudDialog.Close(DialogResult.Ok(true));
    }
}
