<MudDialog>
    <TitleContent>
        <MudStack Row="true" AlignItems="AlignItems.Center" Spacing="3">
            <MudChip T="string" Class="@ResultChipClass(Match.Result, Match.Status)">
                @(Match.Status == EMatchStatus.Upcoming ? "Upcoming" : Match.Result?.ToString())
            </MudChip>
            <div>
                <MudText Typo="Typo.h6" Class="mdd__title">TTF Esports vs @Match.OpponentName</MudText>
                <MudText Typo="Typo.caption" Class="mdd__meta">
                    @Match.MatchdayLabel &nbsp;·&nbsp;
                    @(Match.Venue == EVenue.Home ? "Home" : "Away") &nbsp;·&nbsp;
                    @Match.MatchDate.ToString("dd MMM yyyy")
                </MudText>
            </div>
            @if (Match.Status == EMatchStatus.Finished)
            {
                <MudSpacer />
                <MudText Typo="Typo.h4" Class="mdd__score">@Match.GoalsFor — @Match.GoalsAgainst</MudText>
            }
        </MudStack>
    </TitleContent>
    <DialogContent>
        <MudTabs Elevation="0" Color="Color.Warning">

            <!-- MATCH FACTS -->
            <MudTabPanel Text="MATCH FACTS">
                @if (!_hasTeamStats)
                {
                    <MudText Typo="Typo.body2" Class="mdd__no-data">No match facts recorded.</MudText>
                }
                else
                {
                    <MudGrid Spacing="3" Class="mt-2">
                        @StatRow("Possession %", Match.PossessionPct, null, "%")
                        @StatRow("Shots", Match.ShotsFor, Match.ShotsAgainst, "")
                        @StatRow("Passes Attempted", Match.PassesAttempted, null, "")
                        @StatRow("Pass Accuracy %", Match.PassAccuracyPct, null, "%")
                        @StatRow("Tackles", Match.TacklesFor, Match.TacklesAgainst, "")
                    </MudGrid>
                }
            </MudTabPanel>

            <!-- PLAYER STATS -->
            <MudTabPanel Text="PLAYER STATS">
                @if (!Match.PerformanceStats.Any())
                {
                    <MudText Typo="Typo.body2" Class="mdd__no-data">No player stats recorded.</MudText>
                }
                else
                {
                    <MudTable T="MatchPerformanceStat" Items="Match.PerformanceStats.OrderByDescending(s => s.MatchRating)"
                              Dense="true" Elevation="0">
                        <HeaderContent>
                            <MudTh>Player</MudTh><MudTh>Pos</MudTh>
                            <MudTh>⚽</MudTh><MudTh>🅰</MudTh>
                            <MudTh>Pass%</MudTh><MudTh>Shot%</MudTh>
                            <MudTh>Tackles</MudTh><MudTh>Int</MudTh><MudTh>Saves</MudTh>
                            <MudTh>Rating</MudTh>
                        </HeaderContent>
                        <RowTemplate>
                            <MudTd><MudText Typo="Typo.body2" Class="mdd__player-alias">@context.Player?.Alias</MudText></MudTd>
                            <MudTd><MudChip T="string" Size="Size.Small" Class="ttf-chip--dark">@context.Player?.PrimaryPosition?.Code</MudChip></MudTd>
                            <MudTd>@context.Goals</MudTd>
                            <MudTd>@context.Assists</MudTd>
                            <MudTd>@(context.PassAccuracyPct?.ToString("F0") ?? "-")%</MudTd>
                            <MudTd>@(context.ShotAccuracyPct?.ToString("F0") ?? "-")%</MudTd>
                            <MudTd>@context.TacklesWon/@context.Tackles</MudTd>
                            <MudTd>@context.Interceptions</MudTd>
                            <MudTd>@context.Saves</MudTd>
                            <MudTd><MudChip T="string" Size="Size.Small" Class="ttf-chip--gold">@(context.MatchRating?.ToString("F1") ?? "-")</MudChip></MudTd>
                        </RowTemplate>
                    </MudTable>
                }
            </MudTabPanel>

        </MudTabs>
    </DialogContent>
    <DialogActions>
        <MudButton OnClick="@(() => MudDialog.Close(DialogResult.Ok(true)))" Variant="Variant.Text">Close</MudButton>
    </DialogActions>
</MudDialog>

@code {
    [CascadingParameter] private IMudDialogInstance MudDialog { get; set; } = null!;
    [Parameter] public Match Match { get; set; } = null!;

    private bool _hasTeamStats => Match.PossessionPct.HasValue || Match.ShotsFor.HasValue ||
                                   Match.PassAccuracyPct.HasValue || Match.TacklesFor.HasValue;

    private RenderFragment StatRow(string label, object? ttfVal, object? oppVal, string unit) => __builder =>
    {
        <MudItem xs="12">
            <MudStack Row="true" AlignItems="AlignItems.Center" Spacing="2">
                <MudText Typo="Typo.body2" Style="min-width:160px">@label</MudText>
                <MudChip T="string" Size="Size.Small" Class="ttf-chip--gold">
                    TTF: @(ttfVal ?? "—")@unit
                </MudChip>
                @if (oppVal is not null)
                {
                    <MudChip T="string" Size="Size.Small" Class="ttf-chip--dark">
                        OPP: @oppVal@unit
                    </MudChip>
                }
            </MudStack>
        </MudItem>
    };

    private static string ResultChipClass(EMatchResult? r, EMatchStatus status)
    {
        if (status == EMatchStatus.Upcoming) return "";
        return r switch
        {
            EMatchResult.W => "ttf-chip--win",
            EMatchResult.D => "ttf-chip--draw",
            EMatchResult.L => "ttf-chip--loss",
            _ => ""
        };
    }
}
