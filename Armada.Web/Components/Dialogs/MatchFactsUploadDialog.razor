@using Microsoft.AspNetCore.Components.Forms
@inject IAiParserService AiParserService
@inject IMatchService MatchService

<MudDialog>
    <DialogContent>
        <MudStack Spacing="3">
            <MudSelect T="int" @bind-Value="_matchId" Label="Match" @bind-Value:after="OnMatchChanged" Variant="Variant.Outlined" FullWidth="true">
                @foreach (var m in Matches.Where(m => m.Status == EMatchStatus.Finished))
                {
                    <MudSelectItem T="int" Value="@m.Id">@m.MatchDate.ToString("dd MMM") — vs @m.OpponentName</MudSelectItem>
                }
            </MudSelect>

            <MudSelect T="string" @bind-Value="_ttfSide" Label="TTF is playing as" Variant="Variant.Outlined" FullWidth="true">
                <MudSelectItem T="string" Value="@("right")">Right column (GREEN — Home)</MudSelectItem>
                <MudSelectItem T="string" Value="@("left")">Left column (BLUE — Away)</MudSelectItem>
            </MudSelect>

            @* Fixed: removed Style="pointer-events:none;" from button — now uses shared ttf-file-btn class *@
            <InputFile id="facts-file-input" OnChange="OnFileSelected" accept="image/*" class="ttf-file-input" />
            <label for="facts-file-input" class="ttf-file-label @(_fileName != null ? "ttf-file-label--loaded" : "")">
                <MudButton Variant="Variant.Outlined" FullWidth="true"
                           StartIcon="@Icons.Material.Filled.Image" Class="ttf-file-btn">
                    @(_fileName ?? "SELECT MATCH FACTS SCREENSHOT")
                </MudButton>
            </label>

            <MudButton Variant="Variant.Filled" Color="Color.Warning" FullWidth="true"
                       Disabled="@(_imageBase64 is null || _matchId == 0 || _parsing)"
                       OnClick="Parse">
                @(_parsing ? "ANALYSING..." : "EXTRACT MATCH FACTS WITH AI")
            </MudButton>

            @if (_error is not null)
            {
                <MudAlert Severity="Severity.Error" Dense="true">@_error</MudAlert>
            }

            @if (_facts is not null)
            {
                <MudDivider />
                <MudText Typo="Typo.caption" Class="ttf-rows-label">REVIEW EXTRACTED FACTS</MudText>
                <MudGrid Spacing="2">
                    <MudItem xs="6">
                        <MudNumericField T="byte?" @bind-Value="_facts.PossessionPct" Label="Possession %" Variant="Variant.Outlined" FullWidth="true" Min="0" Max="100" />
                    </MudItem>
                    <MudItem xs="6">
                        <MudNumericField T="byte?" @bind-Value="_facts.PassAccuracyPct" Label="Pass Accuracy %" Variant="Variant.Outlined" FullWidth="true" Min="0" Max="100" />
                    </MudItem>
                    <MudItem xs="6">
                        <MudNumericField T="byte?" @bind-Value="_facts.ShotsFor" Label="Shots (TTF)" Variant="Variant.Outlined" FullWidth="true" Min="0" />
                    </MudItem>
                    <MudItem xs="6">
                        <MudNumericField T="byte?" @bind-Value="_facts.ShotsAgainst" Label="Shots (Opponent)" Variant="Variant.Outlined" FullWidth="true" Min="0" />
                    </MudItem>
                    <MudItem xs="6">
                        <MudNumericField T="short?" @bind-Value="_facts.PassesAttempted" Label="Passes Attempted" Variant="Variant.Outlined" FullWidth="true" Min="0" />
                    </MudItem>
                    <MudItem xs="6">
                        <MudNumericField T="byte?" @bind-Value="_facts.TacklesFor" Label="Tackles (TTF)" Variant="Variant.Outlined" FullWidth="true" Min="0" />
                    </MudItem>
                    <MudItem xs="6">
                        <MudNumericField T="byte?" @bind-Value="_facts.TacklesAgainst" Label="Tackles (Opponent)" Variant="Variant.Outlined" FullWidth="true" Min="0" />
                    </MudItem>
                </MudGrid>

                <MudButton Variant="Variant.Filled" Color="Color.Warning" FullWidth="true" OnClick="Confirm">
                    CONFIRM &amp; SAVE
                </MudButton>
            }
        </MudStack>
    </DialogContent>
    <DialogActions>
        <MudButton OnClick="@(() => MudDialog.Close(DialogResult.Ok(true)))" Variant="Variant.Text">CLOSE</MudButton>
    </DialogActions>
</MudDialog>

@code {
    [CascadingParameter] private IMudDialogInstance MudDialog { get; set; } = null!;
    [Parameter] public List<Match> Matches { get; set; } = [];

    private int _matchId;
    private string _ttfSide = "right";
    private int _prevMatchId;
    private string? _imageBase64;
    private string? _mimeType;
    private string? _fileName;
    private bool _parsing;
    private string? _error;
    private MatchFactsResult? _facts;

    private void OnMatchChanged()
    {
        if (_matchId == _prevMatchId) return;
        _prevMatchId = _matchId;
        var match = Matches.FirstOrDefault(m => m.Id == _matchId);
        if (match is not null)
            _ttfSide = match.Venue == EVenue.Home ? "right" : "left";
    }

    private async Task OnFileSelected(InputFileChangeEventArgs e)
    {
        var file = e.File;
        _fileName = file.Name;
        _mimeType = file.ContentType;
        using var ms = new MemoryStream();
        await file.OpenReadStream(maxAllowedSize: 10 * 1024 * 1024).CopyToAsync(ms);
        _imageBase64 = Convert.ToBase64String(ms.ToArray());
    }

    private async Task Parse()
    {
        _error = null;
        _facts = null;
        _parsing = true;
        try
        {
            _facts = await AiParserService.ExtractMatchFactsAsync(_imageBase64!, _mimeType!, _ttfSide);
        }
        catch (Exception ex)
        {
            _error = ex.Message;
        }
        finally
        {
            _parsing = false;
        }
    }

    private async Task Confirm()
    {
        if (_facts is null || _matchId == 0) return;
        await MatchService.UpdateMatchFactsAsync(_matchId, _facts.PossessionPct, _facts.ShotsFor,
            _facts.ShotsAgainst, _facts.PassesAttempted, _facts.PassAccuracyPct,
            _facts.TacklesFor, _facts.TacklesAgainst);
        MudDialog.Close(DialogResult.Ok(true));
    }
}
