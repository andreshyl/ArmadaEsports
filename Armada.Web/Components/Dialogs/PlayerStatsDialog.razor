@inject IAttributeService AttributeService

<MudDialog>
    <TitleContent>
        <div class="psd__header">
            <div class="psd__avatar">@Player.JerseyNumber</div>
            <div>
                <div class="psd__name">@Player.Alias</div>
                <div class="psd__meta">@Player.PrimaryPosition?.NameEs &nbsp;·&nbsp; #@Player.JerseyNumber</div>
            </div>
        </div>
    </TitleContent>
    <DialogContent>
        <MudTabs Elevation="0" Color="Color.Warning">

            <MudTabPanel Text="STATS">
                @if (!_matchStats.Any())
                {
                    <div class="psd__empty">No match stats recorded.</div>
                }
                else
                {
                    <MudTable T="MatchPerformanceStat" Items="_matchStats" Dense="true" Elevation="0" Class="psd__table">
                        <HeaderContent>
                            <MudTh>Match</MudTh>
                            <MudTh>⚽</MudTh><MudTh>🅰</MudTh>
                            <MudTh>Pass%</MudTh><MudTh>Shot%</MudTh><MudTh>Rating</MudTh>
                        </HeaderContent>
                        <RowTemplate>
                            <MudTd>
                                <div class="psd__match-label">vs @context.Match?.OpponentName</div>
                                <div class="psd__match-date">@context.Match?.MatchDate.ToString("dd MMM")</div>
                            </MudTd>
                            <MudTd>@context.Goals</MudTd>
                            <MudTd>@context.Assists</MudTd>
                            <MudTd>@(context.PassAccuracyPct?.ToString("F0") ?? "—")%</MudTd>
                            <MudTd>@(context.ShotAccuracyPct?.ToString("F0") ?? "—")%</MudTd>
                            <MudTd><span class="psd__chip-gold">@(context.MatchRating?.ToString("F1") ?? "—")</span></MudTd>
                        </RowTemplate>
                    </MudTable>
                }
            </MudTabPanel>

            <MudTabPanel Text="MENTAL">
                @if (!_snapshots.Any())
                {
                    <div class="psd__empty">No attribute snapshots recorded.</div>
                }
                else
                {
                    <span class="psd__section-label">PROMEDIO — @_snapshots.Count snapshot(s)</span>
                    <MudGrid Spacing="3" Class="mb-4">
                        @for (int i = 0; i < _attrNames.Length; i++)
                        {
                            var idx = i;
                            <MudItem xs="12" sm="6">
                                <div class="psd__attr-row">
                                    <span class="psd__attr-name">@_attrNames[idx]</span>
                                    <MudProgressLinear Value="@((double)(_avgScores[idx] * 10))"
                                                       Color="Color.Warning" Rounded="true" Size="Size.Small" Class="psd__attr-bar" />
                                    <span class="psd__attr-score">@_avgScores[idx].ToString("F1")</span>
                                </div>
                            </MudItem>
                        }
                    </MudGrid>

                    <div class="psd__overall-row">
                        <span class="psd__section-label">OVERALL</span>
                        <span class="psd__chip-gold psd__chip-lg">@_avgOverall.ToString("F1")</span>
                    </div>

                    <MudDivider Class="my-3" />
                    <span class="psd__section-label">SNAPSHOTS</span>

                    @foreach (var snap in _snapshots)
                    {
                        <div class="psd__snapshot-row">
                            <div>
                                <div class="psd__match-label">@snap.SnapshotDate.ToString("dd MMM yyyy")</div>
                                @if (!string.IsNullOrEmpty(snap.Notes))
                                {
                                    <div class="psd__match-date">@snap.Notes</div>
                                }
                            </div>
                            <div class="psd__snapshot-actions">
                                <span class="psd__chip-gold">@snap.OverallRating.ToString("F1")</span>
                                <AuthorizeView>
                                    <Authorized>
                                        <MudIconButton Icon="@Icons.Material.Filled.Delete" Size="Size.Small"
                                                       Color="Color.Error" OnClick="@(() => DeleteSnapshot(snap.Id))" />
                                    </Authorized>
                                </AuthorizeView>
                            </div>
                        </div>
                    }
                }
            </MudTabPanel>

            <MudTabPanel Text="HISTORY">
                @if (!_matchStats.Any())
                {
                    <div class="psd__empty">No match history.</div>
                }
                else
                {
                    <MudStack Spacing="2">
                        @foreach (var s in _matchStats)
                        {
                            <div class="psd__history-row">
                                <span class="psd__result-badge psd__result-badge--@(s.Match?.Result?.ToString()?.ToLower() ?? "")">
                                    @s.Match?.Result?.ToString()
                                </span>
                                <div class="psd__history-info">
                                    <div class="psd__match-label">vs @s.Match?.OpponentName</div>
                                    <div class="psd__match-date">@s.Match?.MatchDate.ToString("dd MMM yyyy")</div>
                                </div>
                                <span class="psd__stat-inline">⚽ @s.Goals &nbsp; 🅰 @s.Assists</span>
                            </div>
                        }
                    </MudStack>
                }
            </MudTabPanel>
        </MudTabs>
    </DialogContent>
    <DialogActions>
        <MudButton OnClick="@(() => MudDialog.Close(DialogResult.Ok(true)))" Variant="Variant.Text">Close</MudButton>
    </DialogActions>
</MudDialog>

@code {
    [CascadingParameter] private IMudDialogInstance MudDialog { get; set; } = null!;
    [Parameter] public Player Player { get; set; } = null!;

    private List<MatchPerformanceStat> _matchStats = [];
    private List<PlayerAttributeSnapshot> _snapshots = [];
    private decimal[] _avgScores = new decimal[10];
    private decimal _avgOverall;

    private static readonly string[] _attrNames =
    [
        "Comunicación", "Juego en Equipo", "Posicionamiento", "Decisiones",
        "Reacción",     "Creatividad",     "Consistencia",    "Adaptabilidad",
        "Precisión",    "Compostura"
    ];

    protected override async Task OnParametersSetAsync()
    {
        _matchStats = Player.PerformanceStats.OrderByDescending(s => s.Match?.MatchDate).ToList();
        await LoadSnapshots();
    }

    private async Task LoadSnapshots()
    {
        _snapshots = await AttributeService.GetSnapshotsByPlayerAsync(Player.Id);
        _avgScores = AttributeService.ComputeAverageScores(_snapshots);
        _avgOverall = AttributeService.ComputeAverageOverall(_snapshots);
    }

    private async Task DeleteSnapshot(int id)
    {
        await AttributeService.DeleteSnapshotAsync(id);
        await LoadSnapshots();
        StateHasChanged();
    }
}
