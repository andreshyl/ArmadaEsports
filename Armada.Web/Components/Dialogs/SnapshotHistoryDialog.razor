@inject IAttributeService AttributeService
@inject IDialogService DialogService

<MudDialog>
    <DialogContent>
        <MudStack Spacing="2">
            @foreach (var snap in _snapshots)
            {
                var localSnap = snap;
                <MudPaper Class="pa-2" Elevation="0" Outlined="true">
                    <MudStack Row="true" AlignItems="AlignItems.Center" Justify="Justify.SpaceBetween">
                        <MudStack Spacing="0">
                            <MudText Typo="Typo.body2">@localSnap.SnapshotDate.ToString("yyyy-MM-dd")</MudText>
                            <MudChip T="string" Size="Size.Small" Class="ttf-chip--gold">@localSnap.OverallRating.ToString("F1")</MudChip>
                        </MudStack>
                        <MudStack Row="true" Spacing="0">
                            <MudIconButton Icon="@Icons.Material.Filled.Edit" Size="Size.Small"
                                           OnClick="@(() => OpenEdit(localSnap))" />
                            <MudIconButton Icon="@Icons.Material.Filled.Delete" Size="Size.Small"
                                           Color="Color.Error" OnClick="@(() => DeleteSnapshot(localSnap))" />
                        </MudStack>
                    </MudStack>
                    @if (!string.IsNullOrWhiteSpace(localSnap.Notes))
                    {
                        <MudText Typo="Typo.caption" Color="Color.Secondary">@localSnap.Notes</MudText>
                    }
                </MudPaper>
            }
        </MudStack>
    </DialogContent>
    <DialogActions>
        <MudButton OnClick="@(() => MudDialog.Close(DialogResult.Ok(_dirty)))" Variant="Variant.Text">Close</MudButton>
    </DialogActions>
</MudDialog>

@code {
    [CascadingParameter] private IMudDialogInstance MudDialog { get; set; } = null!;
    [Parameter] public Player Player { get; set; } = null!;
    [Parameter] public List<PlayerAttributeSnapshot> Snapshots { get; set; } = [];

    private List<PlayerAttributeSnapshot> _snapshots = [];
    private bool _dirty;

    protected override void OnParametersSet() =>
        _snapshots = Snapshots.OrderByDescending(s => s.SnapshotDate).ToList();

    private async Task OpenEdit(PlayerAttributeSnapshot snap)
    {
        var parameters = new DialogParameters
        {
            { "Player", Player },
            { "Snapshot", snap }
        };
        var dialog = await DialogService.ShowAsync<EditAttributeSnapshotDialog>(
            $"Edit — {snap.SnapshotDate:yyyy-MM-dd}", parameters,
            new DialogOptions { MaxWidth = MaxWidth.Small, FullWidth = true, CloseButton = true });

        if (!(await dialog.Result)!.Canceled)
        {
            var updated = await AttributeService.GetSnapshotsByPlayerAsync(Player.Id);
            _snapshots = updated.OrderByDescending(s => s.SnapshotDate).ToList();
            _dirty = true;
            StateHasChanged();
        }
    }

    private async Task DeleteSnapshot(PlayerAttributeSnapshot snap)
    {
        var dialog = await DialogService.ShowAsync<ConfirmDialog>("Delete Snapshot",
            new DialogParameters { { "Message", $"Delete snapshot from {snap.SnapshotDate:yyyy-MM-dd}? This cannot be undone." } },
            new DialogOptions { MaxWidth = MaxWidth.ExtraSmall, FullWidth = true });

        if (!(await dialog.Result)!.Canceled)
        {
            await AttributeService.DeleteSnapshotAsync(snap.Id);
            _snapshots.Remove(snap);
            _dirty = true;
            StateHasChanged();
        }
    }
}
