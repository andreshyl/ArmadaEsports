@namespace Armada.Web.Components.Pages
@page "/manager"
@attribute [Authorize(Roles = "Manager")]
@inject IPlayerService PlayerService
@inject IMatchService MatchService
@inject ICompetitionService CompetitionService
@inject TtfAuthStateProvider AuthProvider
@inject IAttributeService AttributeService
@inject NavigationManager Nav

<PageTitle>Manager — TTF Esports</PageTitle>

<MudContainer MaxWidth="MaxWidth.Large" Class="ttf-page">

    <MudStack Row="true" AlignItems="AlignItems.Center" Justify="Justify.SpaceBetween" Class="mb-4">
        <MudText Typo="Typo.overline" Class="ttf-section-label">MANAGER DASHBOARD</MudText>
        <AuthorizeView>
            <Authorized>
                <MudStack Row="true" AlignItems="AlignItems.Center" Spacing="2">
                    <MudIcon Icon="@Icons.Material.Filled.AccountCircle" Class="ttf-nav__icon-btn" />
                    <MudText Typo="Typo.body2">@context.User.Identity?.Name</MudText>
                    <MudButton Variant="Variant.Outlined" Color="Color.Default" Size="Size.Small"
                               StartIcon="@Icons.Material.Filled.Logout" OnClick="Logout">
                        Logout
                    </MudButton>
                </MudStack>
            </Authorized>
        </AuthorizeView>
    </MudStack>

    @if (_loading)
    {
        <MudProgressLinear Color="Color.Warning" Indeterminate="true" />
    }
    else
    {
        <MudGrid Spacing="4">

            <!-- PLANTILLA -->
            <MudItem xs="12" md="6">
                <ManagerPlantilla Players="_players" Ratings="_ratings" OnDataChanged="LoadDataAsync" />
            </MudItem>

            <!-- SQUAD PLANNER + COMPETITIONS stacked in right column -->
            <MudItem xs="12" md="6">
                <MudStack Spacing="4">
                    <div class="manager__section-card">
                        <SquadPlanner Players="_players" Ratings="_ratings" />
                    </div>
                    <ManagerCompetitions Competitions="_competitions" OnDataChanged="LoadDataAsync" />
                </MudStack>
            </MudItem>

            <!-- MATCHES -->
            <MudItem xs="12">
                <ManagerMatches Matches="_matches"
                                Competitions="_competitions"
                                OnDataChanged="LoadDataAsync" />
            </MudItem>

        </MudGrid>
    }

</MudContainer>

@code {
    private List<Player> _players = [];
    private List<Competition> _competitions = [];
    private List<Match> _matches = [];
    private Dictionary<int, decimal> _ratings = [];
    private bool _loading = true;

    protected override async Task OnInitializedAsync() => await LoadDataAsync();

    private async Task LoadDataAsync()
    {
        _loading = true;
        _players = await PlayerService.GetAllAsync(includeInactive: true);
        _competitions = await CompetitionService.GetAllAsync(includeInactive: true);
        var upcoming = await MatchService.GetUpcomingAsync();
        var finished = await MatchService.GetFinishedAsync();
        _matches = [.. finished, .. upcoming];
        // Load latest overall rating per player
        _ratings = [];
        foreach (var p in _players)
        {
            var snap = await AttributeService.GetLatestSnapshotAsync(p.Id);
            if (snap is not null)
                _ratings[p.Id] = snap.OverallRating;
        }
        _loading = false;
    }

    private async Task Logout()
    {
        await AuthProvider.LogoutAsync();
        Nav.NavigateTo("/manager/login");
    }
}
