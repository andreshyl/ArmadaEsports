@namespace Armada.Web.Components.Pages.ManagerComponents
@using ArmadaEsports.Core.Interfaces
@using ArmadaEsports.Core.Models
@inject IAttendanceService AttendanceSvc
@inject IPlayerService PlayerSvc
@inject ISnackbar Snackbar
@implements IDisposable

<div class="ma__wrap">

    <div class="ma__header">
        <span class="ma__label">CONTROL DE ASISTENCIA</span>
        <div class="ma__nav">
            <button class="ma__nav-btn" @onclick="PrevMonth">&#8249;</button>
            <span class="ma__month-label">@_currentDate.ToString("MMMM yyyy").ToUpper()</span>
            <button class="ma__nav-btn" @onclick="NextMonth" disabled="@IsCurrentMonth">&#8250;</button>
        </div>
    </div>

    @if (_loading)
    {
        <MudProgressLinear Color="Color.Warning" Indeterminate="true" Class="my-2" />
    }
    else
    {
        <div class="ma__body">

            <div class="ma__calendar-col">
                <div class="ma__cal-headers">
                    <div class="ma__cal-header ma__cal-header--training">LUN</div>
                    <div class="ma__cal-header ma__cal-header--training">MAR</div>
                    <div class="ma__cal-header ma__cal-header--training">MIÉ</div>
                    <div class="ma__cal-header ma__cal-header--training">JUE</div>
                    <div class="ma__cal-header ma__cal-header--rest">VIE</div>
                    <div class="ma__cal-header ma__cal-header--rest">SÁB</div>
                    <div class="ma__cal-header ma__cal-header--rest">DOM</div>
                </div>

                <div class="ma__calendar">
                    @for (int ci = 0; ci < _calendarDays.Count; ci++)
                    {
                        var cell = _calendarDays[ci];

                        @if (cell is null)
                        {
                            <div class="ma__cal-cell ma__cal-cell--empty"></div>
                        }
                        else
                        {
                            var day = cell.Value;
                            var isTraining = IsTrainingDay(day);
                            var isFuture = day > DateOnly.FromDateTime(DateTime.Today);
                            var isSelected = _selectedDay == day;
                            var pct = (!isFuture && isTraining) ? GetDayAttendancePct(day) : (int?)null;
                            var cssClass = $"ma__cal-cell {(isTraining ? "ma__cal-cell--training" : "ma__cal-cell--rest")} {(isSelected ? "ma__cal-cell--active" : "")} {(isFuture ? "ma__cal-cell--future" : "")}";
                            var capturedDay = day; // capture for lambda

                            <div class="@cssClass" @onclick="() => OnDayClick(capturedDay, isTraining, isFuture)">
                                <span class="ma__day-num">@day.Day</span>
                                @if (pct.HasValue)
                                {
                                    <span class="ma__day-pct @GetPctClass(pct.Value)">@pct%</span>
                                }
                            </div>
                        }
                    }
                </div>
            </div>

            <div class="ma__session-col">
                @if (_selectedDay.HasValue)
                {
                    <div class="ma__session-header">
                        <span class="ma__session-date">@_selectedDay.Value.ToString("ddd dd/MM/yyyy").ToUpper()</span>
                        <button class="ma__save-btn" @onclick="SaveSession">GUARDAR</button>
                    </div>
                    <div class="ma__player-list">
                        @for (int pi = 0; pi < _players.Count; pi++)
                        {
                            var p = _players[pi];
                            var present = _sessionChecks.GetValueOrDefault(p.Id, false);
                            var pid = p.Id;
                            <div class="ma__player-row @(present ? "ma__player-row--present" : "")"
                                 @onclick="() => TogglePlayer(pid)">
                                <div class="ma__player-avatar">
                                    @(p.JerseyNumber?.ToString() ?? Initials(p.Alias))
                                </div>
                                <span class="ma__player-alias">@p.Alias</span>
                                <span class="ma__player-pos">@p.PrimaryPosition.Code</span>
                                <div class="ma__check @(present ? "ma__check--on" : "")">
                                    @if (present)
                                    {
                                        <span>&#10003;</span>
                                    }
                                </div>
                            </div>
                        }
                    </div>
                }
                else
                {
                    <div class="ma__session-empty">
                        <span>Selecciona un día de entrenamiento</span>
                    </div>
                }
            </div>
        </div>

        <div class="ma__stats">
            <div class="ma__stats-header">RENDIMIENTO MENSUAL — @_currentDate.ToString("MMMM yyyy").ToUpper()</div>
            <div class="ma__stats-table">
                <div class="ma__stats-row ma__stats-row--head">
                    <span>JUGADOR</span><span>POS</span><span>ASIST.</span><span>TOTAL</span><span>%</span>
                </div>
                @foreach (var p in _players.OrderByDescending(p => GetAttendancePct(p.Id)))
                {
                    var stats = _monthlyStats.GetValueOrDefault(p.Id, (0, _totalSessions));
                    var pct = stats.Total > 0 ? (int)Math.Round((double)stats.Present / stats.Total * 100) : 0;
                    <div class="ma__stats-row">
                        <span class="ma__stats-alias">@p.Alias</span>
                        <span class="ma__stats-pos">@p.PrimaryPosition.Code</span>
                        <span>@stats.Present</span>
                        <span>@stats.Total</span>
                        <div class="ma__bar-wrap">
                            <div class="ma__bar-bg">
                                <div class="ma__bar-fill @GetPctClass(pct)" style="width:@pct%"></div>
                            </div>
                            <span class="@GetPctClass(pct) ma__bar-label">@pct%</span>
                        </div>
                    </div>
                }
            </div>
        </div>
    }
</div>

@code {
    // ── State ─────────────────────────────────────────────
    private DateOnly _currentDate = DateOnly.FromDateTime(DateTime.Today).AddDays(1 - DateTime.Today.Day);
    private List<Player> _players = [];
    private List<TrainingAttendance> _monthAttendance = [];
    private Dictionary<int, (int Present, int Total)> _monthlyStats = [];
    private List<DateOnly?> _calendarDays = []; // flat list — no nested loops
    private DateOnly? _selectedDay;
    private Dictionary<int, bool> _sessionChecks = [];
    private bool _loading = true;
    private int _totalSessions;
    private bool _disposed;

    // ── Computed ──────────────────────────────────────────
    private bool IsCurrentMonth =>
        _currentDate.Year == DateTime.Today.Year &&
        _currentDate.Month == DateTime.Today.Month;

    private static bool IsTrainingDay(DateOnly d) =>
        d.DayOfWeek is DayOfWeek.Monday or DayOfWeek.Tuesday
                    or DayOfWeek.Wednesday or DayOfWeek.Thursday;

    // ── Lifecycle ─────────────────────────────────────────
    protected override async Task OnInitializedAsync() => await LoadAsync();

    private async Task LoadAsync()
    {
        if (_disposed) return;
        _loading = true;
        StateHasChanged();

        try
        {
            _players = await PlayerSvc.GetAllAsync();
            _monthAttendance = await AttendanceSvc.GetByMonthAsync(_currentDate.Year, _currentDate.Month);
            _monthlyStats = await AttendanceSvc.GetMonthlyStatsAsync(_currentDate.Year, _currentDate.Month);
            _totalSessions = _monthlyStats.Values.Select(v => v.Total).FirstOrDefault();
            BuildCalendar();
            _selectedDay = null;
            _sessionChecks = [];
        }
        catch (ObjectDisposedException) { return; }
        catch (Exception ex)
        {
            Snackbar.Add($"Error cargando asistencia: {ex.Message}", Severity.Error);
        }
        finally
        {
            if (!_disposed) { _loading = false; StateHasChanged(); }
        }
    }

    // ── Calendar — flat List<DateOnly?> ───────────────────
    private void BuildCalendar()
    {
        _calendarDays = [];
        var first = _currentDate;
        var last = first.AddMonths(1).AddDays(-1);

        // Monday-first offset
        var dow = (int)first.DayOfWeek;          // Sun=0 Mon=1 ... Sat=6
        var offset = dow == 0 ? 6 : dow - 1;       // Mon=0 ... Sun=6
        var cursor = first.AddDays(-offset);

        while (cursor <= last)
        {
            for (int i = 0; i < 7; i++)
            {
                var d = cursor.AddDays(i);
                _calendarDays.Add(d.Month == _currentDate.Month ? d : (DateOnly?)null);
            }
            cursor = cursor.AddDays(7);
        }
    }

    // ── Event handlers ────────────────────────────────────
    private void OnDayClick(DateOnly day, bool isTraining, bool isFuture)
    {
        if (!isTraining || isFuture) return;
        _selectedDay = day;
        _sessionChecks = _players.ToDictionary(
            p => p.Id,
            p => _monthAttendance.Any(a => a.PlayerId == p.Id && a.SessionDate == day && a.Present));
    }

    private void TogglePlayer(int playerId) =>
        _sessionChecks[playerId] = !_sessionChecks.GetValueOrDefault(playerId);

    private async Task SaveSession()
    {
        if (!_selectedDay.HasValue || _disposed) return;
        await AttendanceSvc.UpsertBatchAsync(_sessionChecks, _selectedDay.Value);
        Snackbar.Add("Asistencia guardada", Severity.Success);
        await LoadAsync();
    }

    private async Task PrevMonth()
    {
        _currentDate = _currentDate.AddMonths(-1);
        await LoadAsync();
    }

    private async Task NextMonth()
    {
        if (IsCurrentMonth) return;
        _currentDate = _currentDate.AddMonths(1);
        await LoadAsync();
    }

    // ── Helpers ───────────────────────────────────────────
    private int GetDayAttendancePct(DateOnly day)
    {
        if (_players.Count == 0) return 0;
        var present = _monthAttendance.Count(a => a.SessionDate == day && a.Present);
        return (int)Math.Round((double)present / _players.Count * 100);
    }

    private int GetAttendancePct(int playerId)
    {
        var s = _monthlyStats.GetValueOrDefault(playerId, (0, _totalSessions));
        return s.Total > 0 ? (int)Math.Round((double)s.Present / s.Total * 100) : 0;
    }

    private static string GetPctClass(int pct) => pct switch
    {
        >= 80 => "ma__pct--high",
        >= 50 => "ma__pct--mid",
        _ => "ma__pct--low"
    };

    private static string Initials(string alias) =>
        alias.Length >= 2 ? alias[..2].ToUpper() : alias.ToUpper();

    public void Dispose() => _disposed = true;
}
