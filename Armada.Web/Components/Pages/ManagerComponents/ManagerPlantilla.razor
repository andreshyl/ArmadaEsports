@namespace Armada.Web.Components.Pages.ManagerComponents
@inject IDialogService DialogService
@inject ISnackbar Snackbar
@inject IPlayerService PlayerService
@inject IAttributeService AttributeService
@inject IJSRuntime JS

<div class="manager__section-card manager__plantilla-wrap">

    <div class="manager__plantilla-header">
        <MudStack Row="true" AlignItems="AlignItems.Center" Justify="Justify.SpaceBetween">
            <MudText Typo="Typo.caption" Class="manager__section-title">PLANTILLA</MudText>
            <MudStack Row="true" Spacing="1">
                <MudButton Size="Size.Small" Variant="Variant.Outlined" Color="Color.Warning"
                           OnClick="OpenCsvPlayerImport">CSV Players</MudButton>
                <MudButton Size="Size.Small" Variant="Variant.Outlined" Color="Color.Warning"
                           OnClick="OpenCsvAttributeImport">CSV Attrs</MudButton>
                <MudButton Size="Size.Small" Variant="Variant.Outlined" Color="Color.Warning"
                           OnClick="ExportAttributesCsv">Export Attrs</MudButton>
                <MudButton Size="Size.Small" Variant="Variant.Outlined" Color="Color.Warning"
                           OnClick="OpenAddPlayer">+ Add Player</MudButton>
            </MudStack>
        </MudStack>
    </div>

    <div class="manager__plantilla-scroll">
        <MudTable T="Player" Items="Players" Dense="true" Elevation="0" Class="plantilla-player-list">
            <HeaderContent>
                <MudTh></MudTh><MudTh>Player</MudTh><MudTh>Pos</MudTh><MudTh>OVR</MudTh><MudTh></MudTh>
            </HeaderContent>
            <RowTemplate>
                <MudTd>
                    <div class="mp__avatar @(context.PrimaryPosition?.Code == "PO" ? "mp__avatar--gk" : "")">
                        @(context.JerseyNumber?.ToString() ?? Initials(context.Alias))
                    </div>
                </MudTd>
                <MudTd>
                    <span class="manager__player-alias">@context.Alias</span>
                </MudTd>
                <MudTd>
                    <MudChip T="string" Size="Size.Small" Class="ttf-chip--dark">
                        @context.PrimaryPosition?.Code
                    </MudChip>
                </MudTd>
                <MudTd>
                    @if (Ratings.TryGetValue(context.Id, out var ovr))
                    {
                        <MudChip T="string" Size="Size.Small" Class="ttf-chip--gold">@ovr.ToString("F1")</MudChip>
                    }
                    else
                    {
                        <span class="mp__no-rating">—</span>
                    }
                </MudTd>
                <MudTd>
                    <MudStack Row="true" Spacing="1">
                        <MudIconButton Icon="@Icons.Material.Filled.Edit" Size="Size.Small"
                                       OnClick="@(() => OpenEditPlayer(context))" />
                        <MudIconButton Icon="@Icons.Material.Filled.BarChart" Size="Size.Small"
                                       OnClick="@(() => OpenSnapshotHistory(context))" />
                        <MudIconButton Icon="@Icons.Material.Filled.AddChart" Size="Size.Small"
                                       OnClick="@(() => OpenAddSnapshot(context))" />
                        <MudIconButton Icon="@Icons.Material.Filled.PersonOff" Size="Size.Small"
                                       Color="Color.Error" OnClick="@(() => DeletePlayer(context))" />
                    </MudStack>
                </MudTd>
            </RowTemplate>
        </MudTable>
    </div>
</div>

@code {
    [Parameter] public List<Player> Players { get; set; } = [];
    [Parameter] public Dictionary<int, decimal> Ratings { get; set; } = [];
    [Parameter] public EventCallback OnDataChanged { get; set; }

    private static readonly string[] AttributeNames =
    [
        "Comunicación", "Juego en Equipo", "Posicionamiento", "Decisiones",
        "Reacción", "Creatividad", "Consistencia", "Adaptabilidad",
        "Precisión", "Compostura"
    ];

    private static string Initials(string alias) =>
        alias.Length >= 2 ? alias[..2].ToUpper() : alias.ToUpper();

    private async Task OpenAddPlayer()
    {
        var dialog = await DialogService.ShowAsync<AddPlayerDialog>("Add Player",
            new DialogOptions { MaxWidth = MaxWidth.Small, FullWidth = true, CloseButton = true });
        if (!(await dialog.Result)!.Canceled) await OnDataChanged.InvokeAsync();
    }

    private async Task OpenEditPlayer(Player p)
    {
        var parameters = new DialogParameters { { "Player", p } };
        var dialog = await DialogService.ShowAsync<EditPlayerDialog>("Edit Player", parameters,
            new DialogOptions { MaxWidth = MaxWidth.Small, FullWidth = true, CloseButton = true });
        if (!(await dialog.Result)!.Canceled) await OnDataChanged.InvokeAsync();
    }

    private async Task OpenAddSnapshot(Player p)
    {
        var parameters = new DialogParameters { { "Player", p } };
        await DialogService.ShowAsync<AddAttributeSnapshotDialog>($"Mental Attrs — {p.Alias}", parameters,
            new DialogOptions { MaxWidth = MaxWidth.Small, FullWidth = true, CloseButton = true });
    }

    private async Task OpenSnapshotHistory(Player p)
    {
        var snapshots = await AttributeService.GetSnapshotsByPlayerAsync(p.Id);
        if (!snapshots.Any())
        {
            await DialogService.ShowAsync<ConfirmDialog>("No Snapshots",
                new DialogParameters { { "Message", $"{p.Alias} has no recorded attribute snapshots." } },
                new DialogOptions { MaxWidth = MaxWidth.ExtraSmall, FullWidth = true });
            return;
        }

        var parameters = new DialogParameters
        {
            { "Player", p },
            { "Snapshots", snapshots }
        };
        var dialog = await DialogService.ShowAsync<SnapshotHistoryDialog>($"Snapshots — {p.Alias}", parameters,
            new DialogOptions { MaxWidth = MaxWidth.Small, FullWidth = true, CloseButton = true });

        var result = await dialog.Result;
        if (result is { Canceled: false, Data: true })
            await OnDataChanged.InvokeAsync();
    }

    private async Task DeletePlayer(Player p)
    {
        var result = await DialogService.ShowAsync<ConfirmDialog>("Remove Player",
            new DialogParameters { { "Message", $"Remove {p.Alias} from the squad? This cannot be undone." } },
            new DialogOptions { MaxWidth = MaxWidth.ExtraSmall, FullWidth = true });

        if (!(await result.Result)!.Canceled)
        {
            var success = await PlayerService.DeactivateAsync(p.Id);
            if (success)
            {
                Snackbar.Add($"{p.Alias} removed from squad.", Severity.Success);
                await OnDataChanged.InvokeAsync();
            }
            else
            {
                Snackbar.Add($"Could not remove {p.Alias}. Player not found.", Severity.Error);
            }
        }
    }

    private async Task ExportAttributesCsv()
    {
        var sb = new System.Text.StringBuilder();
        sb.Append("Alias,Posicion,Fecha,OVR");
        foreach (var name in AttributeNames)
            sb.Append($",{name}");
        sb.AppendLine();

        foreach (var player in Players)
        {
            var snapshots = await AttributeService.GetSnapshotsByPlayerAsync(player.Id);
            foreach (var snap in snapshots)
            {
                sb.Append($"{player.Alias},{player.PrimaryPosition?.Code},{snap.SnapshotDate:yyyy-MM-dd},{snap.OverallRating:F1}");
                for (byte i = 0; i < 10; i++)
                {
                    var score = snap.Scores.FirstOrDefault(s => s.AttributeIndex == i)?.Score ?? 0;
                    sb.Append($",{score}");
                }
                sb.AppendLine();
            }
        }

        var filename = $"armada_attributes_{DateTime.Today:yyyyMMdd}.csv";
        var bytes = System.Text.Encoding.UTF8.GetBytes(sb.ToString());
        var base64 = Convert.ToBase64String(bytes);
        await JS.InvokeVoidAsync("downloadBase64File", base64, filename, "text/csv");
    }

    private async Task OpenCsvAttributeImport()
    {
        var parameters = new DialogParameters { { "Players", Players } };
        var dialog = await DialogService.ShowAsync<CsvAttributeUploadDialog>("CSV Attribute Import", parameters,
            new DialogOptions { MaxWidth = MaxWidth.Small, FullWidth = true, CloseButton = true });
        if (!(await dialog.Result)!.Canceled) await OnDataChanged.InvokeAsync();
    }

    private async Task OpenCsvPlayerImport()
    {
        var dialog = await DialogService.ShowAsync<CsvPlayerImportDialog>("CSV Player Import",
            new DialogOptions { MaxWidth = MaxWidth.Medium, FullWidth = true, CloseButton = true });
        if (!(await dialog.Result)!.Canceled) await OnDataChanged.InvokeAsync();
    }
}
