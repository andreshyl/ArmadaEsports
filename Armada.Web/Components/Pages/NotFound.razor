@layout MainLayout
@page "/404"

<PageTitle>Not Found — TTF Esports</PageTitle>

<MudContainer MaxWidth="MaxWidth.Small" Class="ttf-page">
    <MudStack AlignItems="AlignItems.Center" Spacing="4">
        <MudText Typo="Typo.h1" Class="notfound__code">404</MudText>
        <MudText Typo="Typo.h6" Class="notfound__message">Page not found.</MudText>
        <MudButton Href="/" Variant="Variant.Filled" Color="Color.Warning">Back to Home</MudButton>
    </MudStack>
</MudContainer>
